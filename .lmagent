# LMAgent Framework Marker
# Este archivo indica que este proyecto usa LMAgent Framework.
# Los agentes de IA deben leer AGENTS.md antes de trabajar.

framework: lmagent
version: "2.1.0"

# AGENTS.md es el punto de entrada principal (estándar de la industria)
# Ver: https://agents.md

# Instrucciones para agentes de IA:
# 1. Lee AGENTS.md para entender el framework y el flujo de trabajo
# 2. Usa las personas definidas en personas/ según la tarea
# 3. Sigue las reglas en rules/
# 4. SIEMPRE actualiza la documentación

first_read:
  - "AGENTS.md"

personas_dir: "personas"
workflows_dir: "workflows"
rules_dir: "rules"
config_dir: "config"
